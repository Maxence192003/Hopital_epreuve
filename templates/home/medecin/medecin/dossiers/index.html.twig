{% extends '@medecin/layout_dossiers.html.twig' %}

{% block main %}
<div class="container mt-5">

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <!-- Titre Section -->
    <div class="row mb-4">
        <div class="col-md-12">
            <h2><i class="fas fa-folder-open"></i> Dossiers Patients</h2>
            <p class="text-muted">Consultez les dossiers de vos patients</p>
        </div>
    </div>

    <!-- Contenu -->
    {% if dossiers|length == 0 %}
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Aucun dossier patient trouvé.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Date de Naissance</th>
                        <th>État de la Greffe</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for dossier in dossiers %}
                    <tr>
                        <td><strong>{{ dossier.utilisateur.nom }}</strong></td>
                        <td>{{ dossier.utilisateur.prenom }}</td>
                        <td>
                            {% if dossier.dateNaissance %}
                                {{ dossier.dateNaissance|date('d/m/Y') }}
                            {% else %}
                                <em class="text-muted">Non renseigné</em>
                            {% endif %}
                        </td>
                        <td>
                            {% if dossier.etatGreffe %}
                                <span class="badge bg-primary">{{ dossier.etatGreffe }}</span>
                            {% else %}
                                <span class="badge bg-secondary">Aucun État</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a href="{{ path('medecin_dossier_voir', {id: dossier.idDossierPatient}) }}" class="btn btn-info" title="Voir">
                                    <i class="fas fa-eye"></i> Voir
                                </a>
                                <a href="{{ path('medecin_dossier_modifier', {id: dossier.idDossierPatient}) }}" class="btn btn-warning" title="Modifier">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="mt-4">
        <a href="{{ path('app_medecin_accueil') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>
</div>
{% endblock %}
