<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f5f7fa; margin: 0; }
        .header { background: linear-gradient(135deg, #0066cc, #004499); color: white; padding: 20px; }
        .header h1 { margin: 0; }
        .main { max-width: 1200px; margin: 40px auto; padding: 0 20px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .card h3 { color: #0066cc; margin: 0 0 10px 0; }
        .card p { margin: 0; color: #666; }
    </style>
</head>
<body>
    <div class="header">
        <h1>🏥 Institut de Greffe - Admin</h1>
        <p>Tableau de bord d'administration</p>
    </div>
    
    <div class="main">
        <h2>Tableau de bord EasyAdmin</h2>
        <div class="grid">
            <div class="card">
                <h3>📝 Logins</h3>
                <p>Gérer les accès</p>
            </div>
            <div class="card">
                <h3>👥 Utilisateurs</h3>
                <p>Gérer les utilisateurs</p>
            </div>
            <div class="card">
                <h3>🏷️ Profils</h3>
                <p>Gérer les rôles</p>
            </div>
        </div>
    </div>
</body>
</html>
