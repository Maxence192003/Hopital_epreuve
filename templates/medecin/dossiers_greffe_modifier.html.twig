{% extends '@medecin/layout.html.twig' %}

{% block main %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h2>Modifier l'état de la greffe</h2>
            <p class="text-muted">Patient: <strong>{{ utilisateur.prenom }} {{ utilisateur.nom }}</strong></p>
            
            <form method="POST" class="mt-4">
                <!-- Informations Patient -->
                <h5 class="mt-4 mb-3">Informations Patient</h5>
                
                <div class="form-group mb-3">
                    <label class="form-label">Nom</label>
                    <input type="text" class="form-control" value="{{ utilisateur.nom }}" disabled>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Prénom</label>
                    <input type="text" class="form-control" value="{{ utilisateur.prenom }}" disabled>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Date de Naissance</label>
                    <input type="text" class="form-control" value="{{ dossier.dateNaissance ? dossier.dateNaissance|date('d/m/Y') : 'Non renseignée' }}" disabled>
                </div>

                <!-- État de la Greffe -->
                <h5 class="mt-4 mb-3">État de la Greffe</h5>
                
                <div class="form-group mb-3">
                    <label for="etat_greffe" class="form-label">État de la Greffe <span class="text-danger">*</span></label>
                    <select id="etat_greffe" name="etat_greffe" class="form-select" required>
                        <option value="">-- Sélectionnez un état --</option>
                        <option value="En attente" {% if dossier.etatGreffe == 'En attente' %}selected{% endif %}>En attente</option>
                        <option value="Prévu" {% if dossier.etatGreffe == 'Prévu' %}selected{% endif %}>Prévu</option>
                        <option value="Réalisé" {% if dossier.etatGreffe == 'Réalisé' %}selected{% endif %}>Réalisé</option>
                        <option value="Annulé" {% if dossier.etatGreffe == 'Annulé' %}selected{% endif %}>Annulé</option>
                        <option value="Reporté" {% if dossier.etatGreffe == 'Reporté' %}selected{% endif %}>Reporté</option>
                    </select>
                    <small class="form-text text-muted">Cet état indique le statut actuel de la greffe du patient</small>
                </div>

                <!-- Boutons -->
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                    <a href="{{ path('medecin_dossiers_greffe_liste') }}" class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}
