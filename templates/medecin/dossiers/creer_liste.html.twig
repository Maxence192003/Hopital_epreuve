{% extends '@medecin/layout_dossiers.html.twig' %}

{% block main %}
<div class="container mt-5">

    <!-- Titre Section -->
    <div class="row mb-4">
        <div class="col-md-12">
            <h2><i class="fas fa-plus-circle"></i> Créer un Dossier Patient</h2>
            <p class="text-muted">Sélectionnez un patient pour créer son dossier</p>
        </div>
    </div>

    <!-- Contenu -->
    {% if patients|length == 0 %}
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Tous les patients ont déjà un dossier.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Ville</th>
                        <th>Email</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for patient in patients %}
                    <tr>
                        <td><strong>{{ patient.nom }}</strong></td>
                        <td>{{ patient.prenom }}</td>
                        <td>{{ patient.villeRes }}</td>
                        <td>{{ patient.login.mail }}</td>
                        <td>
                            <a href="{{ path('medecin_dossier_creer', {id: patient.idUtilisateur}) }}" class="btn btn-sm btn-success">
                                <i class="fas fa-plus"></i> Créer Dossier
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="mt-4">
        <a href="{{ path('app_medecin_accueil') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>
</div>
{% endblock %}
