{% extends '@medecin/layout_dossiers.html.twig' %}

{% block main %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h2>Ajouter une Greffe</h2>
            <p class="text-muted">Patient: <strong>{{ utilisateur.prenom }} {{ utilisateur.nom }}</strong></p>
            
            <form method="POST" class="mt-4">
                <!-- Informations Patient (Read-Only) -->
                <h5 class="mt-4 mb-3">Informations Patient</h5>
                
                <div class="form-group mb-3">
                    <label class="form-label">Nom</label>
                    <input type="text" class="form-control" value="{{ utilisateur.nom }}" disabled>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Prénom</label>
                    <input type="text" class="form-control" value="{{ utilisateur.prenom }}" disabled>
                </div>

                <!-- Informations Greffe -->
                <h5 class="mt-4 mb-3">Informations Greffe</h5>
                
                <div class="form-group mb-3">
                    <label for="date_greffe" class="form-label">Date de Greffe <span class="text-danger">*</span></label>
                    <input type="datetime-local" id="date_greffe" name="date_greffe" class="form-control" required>
                </div>

                <div class="form-group mb-3">
                    <label for="note_greffe" class="form-label">Note Greffe</label>
                    <textarea id="note_greffe" name="note_greffe" class="form-control" rows="4" placeholder="Informations sur la greffe..."></textarea>
                    <small class="form-text text-muted">Optionnel</small>
                    
                    <!-- Accordéon aide pour note_greffe -->
                    <div class="accordion mt-2" id="accordionGreffe">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseGreffe" aria-expanded="false" aria-controls="collapseGreffe">
                                    💡 Questions guidées pour la note greffe
                                </button>
                            </h2>
                            <div id="collapseGreffe" class="accordion-collapse collapse" data-bs-parent="#accordionGreffe">
                                <div class="accordion-body bg-light">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">1. Conditions opératoires et état du greffon</label>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="form-label small">Temps d'ischémie froide (heures:minutes)</label>
                                                <input type="text" id="temps_ischemie" class="form-control form-control-sm" placeholder="ex: 4h30">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">État macroscopique du greffon</label>
                                                <select id="etat_macroscopique" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="Parfait">Parfait</option>
                                                    <option value="Bon">Bon</option>
                                                    <option value="Acceptable">Acceptable</option>
                                                    <option value="Dégradé">Dégradé</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">2. Gestes opératoires</label>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="form-label small">Durée des anastomoses (minutes)</label>
                                                <input type="number" id="duree_anastomoses" class="form-control form-control-sm" placeholder="ex: 45">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Sonde JJ utilisée ?</label>
                                                <select id="sonde_jj" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="Oui">Oui</option>
                                                    <option value="Non">Non</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">3. Complications peropératoires</label>
                                        <textarea id="complications_perop" class="form-control form-control-sm" rows="2" placeholder="Saignements, dégâts nerveux, thrombose, etc..."></textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">4. Observations cliniques post-opératoires immédiates</label>
                                        <textarea id="observations_postop" class="form-control form-control-sm" rows="2" placeholder="Diurèse, créatinine J1, état du greffon, etc..."></textarea>
                                    </div>

                                    <button type="button" class="btn btn-sm btn-primary me-2" onclick="genererNoteGreffe()">
                                        📝 Générer la note
                                    </button>
                                    <small class="text-muted">Les informations saisies seront formatées automatiquement</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="note_donneur" class="form-label">Note Donneur</label>
                    <textarea id="note_donneur" name="note_donneur" class="form-control" rows="4" placeholder="Informations sur le donneur..."></textarea>
                    <small class="form-text text-muted">Optionnel</small>

                    <!-- Accordéon aide pour note_donneur -->
                    <div class="accordion mt-2" id="accordionDonneur">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDonneur" aria-expanded="false" aria-controls="collapseDonneur">
                                    💡 Questions guidées pour le donneur
                                </button>
                            </h2>
                            <div id="collapseDonneur" class="accordion-collapse collapse" data-bs-parent="#accordionDonneur">
                                <div class="accordion-body bg-light">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">1. Profil du donneur</label>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="form-label small">Type de donneur</label>
                                                <select id="type_donneur" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="Donneur décédé (mort encéphalique)">Mort encéphalique</option>
                                                    <option value="Donneur décédé (mort cardiaque)">Mort cardiaque</option>
                                                    <option value="Donneur vivant (apparenté)">Donneur vivant apparenté</option>
                                                    <option value="Donneur vivant (non-apparenté)">Donneur vivant non-apparenté</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Âge du donneur (ans)</label>
                                                <input type="number" id="age_donneur" class="form-control form-control-sm" placeholder="ex: 45">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">2. Caractéristiques biologiques</label>
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="form-label small">Groupe sanguin</label>
                                                <select id="groupe_sanguin_donneur" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="O">O</option>
                                                    <option value="A">A</option>
                                                    <option value="B">B</option>
                                                    <option value="AB">AB</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Sexe</label>
                                                <select id="sexe_donneur" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="M">Masculin</option>
                                                    <option value="F">Féminin</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Créatinine (μmol/l)</label>
                                                <input type="number" id="creatinine_donneur" class="form-control form-control-sm" placeholder="ex: 85">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">3. Profil de risque infectieux</label>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="form-label small">Sérologie CMV</label>
                                                <select id="serologie_cmv" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="Positif (+)">Positif (+)</option>
                                                    <option value="Négatif (-)">Négatif (-)</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Sérologie EBV</label>
                                                <select id="serologie_ebv" class="form-select form-select-sm">
                                                    <option value="">-- Sélectionner --</option>
                                                    <option value="Positif (+)">Positif (+)</option>
                                                    <option value="Négatif (-)">Négatif (-)</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">4. Compatibilité HLA (si disponible)</label>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="form-label small">HLA A</label>
                                                <input type="text" id="hla_a" class="form-control form-control-sm" placeholder="ex: 01-02">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">HLA B</label>
                                                <input type="text" id="hla_b" class="form-control form-control-sm" placeholder="ex: 07-35">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">5. Observations supplémentaires</label>
                                        <textarea id="observations_donneur" class="form-control form-control-sm" rows="2" placeholder="Antécédents pertinents, maladies chroniques, remarques..."></textarea>
                                    </div>

                                    <button type="button" class="btn btn-sm btn-primary me-2" onclick="genererNoteDonneur()">
                                        📝 Générer la note
                                    </button>
                                    <small class="text-muted">Les informations saisies seront formatées automatiquement</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Boutons -->
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Ajouter la Greffe
                    </button>
                    <a href="{{ path('medecin_dossiers_sans_greffe') }}" class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .text-danger {
        color: #dc3545;
    }
    
    .form-label {
        font-weight: 500;
        margin-bottom: 0.5rem;
    }
    
    h5 {
        color: #333;
        border-bottom: 2px solid #667eea;
        padding-bottom: 0.5rem;
    }

    .accordion-button:not(.collapsed) {
        background-color: #e7f3ff;
        color: #0c63e4;
    }

    .accordion-body {
        border-top: 1px solid #dee2e6;
    }

    .form-select-sm {
        font-size: 0.875rem;
    }
</style>

<script>
function genererNoteGreffe() {
    const tempsIschemie = document.getElementById('temps_ischemie').value;
    const etatMacroscopique = document.getElementById('etat_macroscopique').value;
    const dureeAnastomoses = document.getElementById('duree_anastomoses').value;
    const sondeJJ = document.getElementById('sonde_jj').value;
    const complicationsProp = document.getElementById('complications_perop').value;
    const observationsPostop = document.getElementById('observations_postop').value;

    let note = "RAPPORT DE GREFFE RÉNALE\n";
    note += "=".repeat(50) + "\n\n";

    note += "DONNÉES OPÉRATOIRES\n";
    note += "-".repeat(50) + "\n";
    
    if (tempsIschemie) {
        note += "• Temps d'ischémie froide: " + tempsIschemie + "\n";
    }
    
    if (etatMacroscopique) {
        note += "• État macroscopique du greffon: " + etatMacroscopique + "\n";
    }
    
    if (dureeAnastomoses) {
        note += "• Durée des anastomoses: " + dureeAnastomoses + " minutes\n";
    }
    
    if (sondeJJ) {
        note += "• Sonde JJ: " + sondeJJ + "\n";
    }

    if (complicationsProp) {
        note += "\nCOMPLICATIONS PEROPÉRATOIRES\n";
        note += "-".repeat(50) + "\n";
        note += complicationsProp + "\n";
    }

    if (observationsPostop) {
        note += "\nOBSERVATIONS POST-OPÉRATOIRES IMMÉDIATES\n";
        note += "-".repeat(50) + "\n";
        note += observationsPostop + "\n";
    }

    document.getElementById('note_greffe').value = note.trim();
    
    // Scroll vers la note
    document.getElementById('note_greffe').scrollIntoView({ behavior: 'smooth' });
    document.getElementById('note_greffe').focus();
}

function genererNoteDonneur() {
    const typeDonneur = document.getElementById('type_donneur').value;
    const ageDonneur = document.getElementById('age_donneur').value;
    const groupeSanguin = document.getElementById('groupe_sanguin_donneur').value;
    const sexe = document.getElementById('sexe_donneur').value;
    const creatinine = document.getElementById('creatinine_donneur').value;
    const cmv = document.getElementById('serologie_cmv').value;
    const ebv = document.getElementById('serologie_ebv').value;
    const hlaA = document.getElementById('hla_a').value;
    const hlaB = document.getElementById('hla_b').value;
    const observations = document.getElementById('observations_donneur').value;

    let note = "FICHE DONNEUR\n";
    note += "=".repeat(50) + "\n\n";

    note += "DONNÉES DÉMOGRAPHIQUES\n";
    note += "-".repeat(50) + "\n";
    
    if (typeDonneur) {
        note += "• Type de donneur: " + typeDonneur + "\n";
    }
    
    if (ageDonneur) {
        note += "• Âge: " + ageDonneur + " ans\n";
    }
    
    if (sexe) {
        note += "• Sexe: " + (sexe === 'M' ? 'Masculin' : 'Féminin') + "\n";
    }
    
    if (groupeSanguin) {
        note += "• Groupe sanguin: " + groupeSanguin + "\n";
    }

    note += "\nPROFIL BIOLOGIQUE\n";
    note += "-".repeat(50) + "\n";
    
    if (creatinine) {
        note += "• Créatinine: " + creatinine + " μmol/l\n";
    }

    note += "\nSÉROLOGIES VIRALES\n";
    note += "-".repeat(50) + "\n";
    
    if (cmv) {
        note += "• CMV: " + cmv + "\n";
    }
    
    if (ebv) {
        note += "• EBV: " + ebv + "\n";
    }

    note += "\nTYPAGE HLA\n";
    note += "-".repeat(50) + "\n";
    
    if (hlaA || hlaB) {
        if (hlaA) note += "• HLA A: " + hlaA + "\n";
        if (hlaB) note += "• HLA B: " + hlaB + "\n";
    } else {
        note += "• Typages non renseignés\n";
    }

    if (observations) {
        note += "\nOBSERVATIONS SUPPLÉMENTAIRES\n";
        note += "-".repeat(50) + "\n";
        note += observations + "\n";
    }

    document.getElementById('note_donneur').value = note.trim();
    
    // Scroll vers la note
    document.getElementById('note_donneur').scrollIntoView({ behavior: 'smooth' });
    document.getElementById('note_donneur').focus();
}
</script>
{% endblock %}
